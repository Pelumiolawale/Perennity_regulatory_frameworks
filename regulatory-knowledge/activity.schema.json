{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://perennitybridge.com/schemas/activity.schema.json",
  "title": "Regulatory Framework",
  "description": "Structured representation of a single framework definition under a sustainable finance regime. Three archetypes: activity_aligned (TSC + DNSH, e.g. EU Taxonomy), product_label (fund-level eligibility, e.g. SFDR / UK SDR), issuance_framework (bond-level use-of-proceeds, e.g. ICMA GBP). The archetype discriminator is optional; JSON without an explicit archetype field is treated as activity_aligned for backward compat with pre-v3.3 framework definitions. Every framework parsed into the Perennity regulatory knowledge base must satisfy this schema. Designed for primary-source traceability and methodology-version auditability.",
  "type": "object",
  "required": [
    "id",
    "framework",
    "framework_version",
    "framework_source_hash",
    "methodology_version",
    "effective_date"
  ],
  "properties": {
    "archetype": {
      "type": "string",
      "enum": ["activity_aligned", "product_label", "issuance_framework"],
      "description": "Framework archetype discriminator. Omitted = activity_aligned (backward-compat default)."
    },

    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Stable internal identifier. Example: eu_tax_climate_8_1"
    },
    "framework": {
      "type": "string",
      "enum": [
        "EU_TAXONOMY_CLIMATE",
        "EU_TAXONOMY_ENVIRONMENTAL",
        "SFDR",
        "UK_SDR",
        "ICMA_GBP",
        "EU_GBS",
        "EIB_CBI",
        "LEED",
        "BREEAM"
      ]
    },
    "framework_version": {
      "type": "string",
      "description": "Canonical version identifier of the framework instrument. Example: Regulation_2021_2139_consolidated_2024"
    },
    "framework_source_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 hash of the canonical source document the data was parsed from. Bump this when the underlying regulation changes."
    },
    "methodology_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+$",
      "description": "Perennity methodology version this framework definition is bound to. Example: v3.2"
    },
    "methodology_vintage": {
      "type": "string",
      "description": "Human-readable vintage of the methodology version. Example: May 2026."
    },
    "effective_date": {
      "type": "string",
      "format": "date",
      "description": "Date from which this framework definition is in force for new reports."
    },
    "supersedes": {
      "type": "string",
      "description": "id of a prior framework definition this one replaces (for change-log traceability)."
    },

    "activity_code": {
      "type": "string",
      "description": "Framework-native activity code. Required for archetype=activity_aligned. Example: 8.1 for EU Taxonomy data processing."
    },
    "activity_name": {
      "type": "string",
      "description": "Required for archetype=activity_aligned."
    },
    "nace_codes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "NACE Rev. 2 codes mapped to this activity, where applicable."
    },
    "environmental_objective": {
      "type": "string",
      "enum": [
        "climate_change_mitigation",
        "climate_change_adaptation",
        "water_and_marine_resources",
        "circular_economy",
        "pollution_prevention",
        "biodiversity_and_ecosystems",
        "not_applicable"
      ],
      "description": "Required for archetype=activity_aligned."
    },
    "substantial_contribution_criteria": {
      "type": "array",
      "items": { "$ref": "#/$defs/criterion" }
    },
    "dnsh_criteria": {
      "type": "array",
      "items": { "$ref": "#/$defs/dnsh_criterion" }
    },
    "methodology_criteria": {
      "type": "array",
      "description": "Perennity Bridge benchmarking criteria (authority_level 2). Render only on the paid report; never contribute to alignment verdict.",
      "items": { "$ref": "#/$defs/criterion" }
    },
    "safeguards_criteria": {
      "type": "array",
      "description": "Minimum-safeguards criteria per Regulation (EU) 2020/852 Article 18. Currently attached under Activity 8.1; will move to framework-level once SFDR / EuGBS frameworks land.",
      "items": { "$ref": "#/$defs/criterion" }
    },
    "minimum_safeguards": {
      "type": "object",
      "description": "Legacy declarative-only safeguards summary; superseded by safeguards_criteria from v3.2 onward. Retained for schema-compat on prior fixtures.",
      "properties": {
        "source_reference": { "type": "string" },
        "requirements": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "label_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Required for archetype=product_label. Example: sfdr_article_8."
    },
    "label_family": {
      "type": "string",
      "enum": ["sfdr", "uk_sdr"],
      "description": "Required for archetype=product_label."
    },
    "eligibility_criteria": {
      "type": "array",
      "items": { "$ref": "#/$defs/product_label_criterion" },
      "description": "Required for archetype=product_label. Flat list of eligibility criteria; there is no SC/DNSH split for product labels."
    },
    "pai_indicators": {
      "type": "array",
      "items": { "$ref": "#/$defs/pai_indicator" },
      "description": "Optional PAI indicator references (SFDR product_label)."
    },
    "entity_attestations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional list of attestation-keys the fund manager must answer at the entity level (e.g. ungc_compliance, board_diversity)."
    },
    "sustainable_investment_commitment": {
      "type": "object",
      "description": "Optional Article 8/9-style minimum proportion of sustainable investments commitment.",
      "properties": {
        "minimum_proportion": { "type": "number", "minimum": 0, "maximum": 1 },
        "categories": { "type": "array", "items": { "type": "string" } }
      }
    },

    "framework_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Required for archetype=issuance_framework. Example: icma_gbp_2021."
    },
    "process_components": {
      "type": "array",
      "items": { "$ref": "#/$defs/issuance_process_component" },
      "description": "Required for archetype=issuance_framework. The four ICMA GBP process components or equivalent."
    },
    "external_review_type": {
      "type": "string",
      "enum": ["second_party_opinion", "verification", "certification", "rating"],
      "description": "Optional declared external review modality for the issuance."
    }
  },

  "allOf": [
    {
      "if": {
        "required": ["archetype"],
        "properties": { "archetype": { "const": "product_label" } }
      },
      "then": {
        "required": ["label_id", "label_family", "eligibility_criteria"]
      }
    },
    {
      "if": {
        "required": ["archetype"],
        "properties": { "archetype": { "const": "issuance_framework" } }
      },
      "then": {
        "required": ["framework_id", "process_components"]
      }
    },
    {
      "if": {
        "anyOf": [
          { "not": { "required": ["archetype"] } },
          {
            "required": ["archetype"],
            "properties": { "archetype": { "const": "activity_aligned" } }
          }
        ]
      },
      "then": {
        "required": ["activity_code", "activity_name", "environmental_objective"]
      }
    }
  ],

  "$defs": {
    "criterion": {
      "type": "object",
      "required": [
        "id",
        "criterion",
        "source_reference",
        "source_text",
        "requirement_type",
        "scoring_logic_ref"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "criterion": {
          "type": "string",
          "description": "Short canonical name for the criterion."
        },
        "source_reference": {
          "type": "string",
          "description": "Anchor inside the regulation. Example: Annex_I_Section_8.1_paragraph_2"
        },
        "source_text": {
          "type": "string",
          "description": "Verbatim regulation text for this criterion. Pulled directly into the paid report as the authoritative quote."
        },
        "requirement_type": {
          "type": "string",
          "enum": [
            "numeric_threshold",
            "compliance_attestation",
            "qualitative_assessment",
            "verification_requirement",
            "benchmarking",
            "rollup"
          ]
        },
        "applies_to": {
          "type": "string",
          "description": "Free-text scoping clause. Example: existing_facilities_built_before_2025"
        },
        "threshold_value": { "type": ["number", "null"] },
        "threshold_operator": {
          "type": ["string", "null"],
          "enum": [
            "less_than",
            "less_than_or_equal",
            "greater_than",
            "greater_than_or_equal",
            "equal_to",
            null
          ]
        },
        "threshold_unit": { "type": ["string", "null"] },
        "threshold_metric": { "type": ["string", "null"] },
        "verification_requirement": {
          "type": ["string", "null"],
          "enum": ["independent_third_party", "self_attestation", "regulator_approved", null]
        },
        "verification_frequency_years": { "type": ["integer", "null"] },
        "data_inputs_required": {
          "type": "array",
          "items": { "$ref": "#/$defs/data_input" }
        },
        "conditional_on": {
          "type": ["string", "null"],
          "description": "Trigger that activates this criterion. Example: water_stressed_region"
        },
        "estimation_allowed": {
          "type": "boolean",
          "description": "Whether the EU Platform Feb 2025 estimation guidance applies."
        },
        "narrative_template_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "References into the DNSH/SC narrative library."
        },
        "scoring_logic_ref": {
          "type": "string",
          "pattern": "^logic\\.[a-z0-9_]+\\.v\\d+$",
          "description": "Reference into versioned scoring code. Example: logic.sc_8_1_2.v1"
        },
        "authority_level": {
          "type": "integer",
          "enum": [1, 2, 3],
          "description": "1 = regulatory attestation; 2 = Perennity Bridge methodology; 3 = informational. Drives renderer routing and heatmap aggregation."
        },
        "authority_source": {
          "type": "string",
          "description": "Free-text citation for the authority backing this criterion."
        },
        "calibration_references": {
          "type": "array",
          "items": { "type": "string" },
          "description": "External datasets / surveys used to calibrate the bands for a benchmarking criterion."
        },
        "snapshot_inclusion": {
          "type": "boolean",
          "description": "If false, the criterion never appears in the free snapshot output (independent of authority_level)."
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Criterion ids that must be scored before this one. The engine resolves dependencies and passes prior results in context."
        },
        "framework_applicability": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Which frameworks treat this criterion as applicable. Example: [eu_taxonomy_aligned, sfdr_article_9, eu_gbs]."
        },
        "render_paths": {
          "type": "array",
          "items": { "type": "string", "enum": ["snapshot", "paid_report"] },
          "description": "Renderer paths where this criterion may appear. Defaults to both when omitted."
        },
        "data_points_required": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Flat list of data_points keys expected on ProjectInput.data_points. Used by intake form generation."
        }
      }
    },
    "dnsh_criterion": {
      "allOf": [
        { "$ref": "#/$defs/criterion" },
        {
          "type": "object",
          "required": ["objective"],
          "properties": {
            "objective": {
              "type": "string",
              "enum": [
                "climate_change_adaptation",
                "water_and_marine_resources",
                "circular_economy",
                "pollution_prevention",
                "biodiversity_and_ecosystems"
              ]
            }
          }
        }
      ]
    },
    "data_input": {
      "type": "object",
      "required": ["field", "type"],
      "properties": {
        "field": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["numeric", "boolean", "structured_list", "free_text", "document_reference"]
        },
        "measurement_standard": {
          "type": "string",
          "description": "Reference to an external measurement standard. Example: EN_50600-4-2"
        },
        "reference_document": { "type": "string" },
        "unit": { "type": "string" },
        "required": { "type": "boolean", "default": true }
      }
    },
    "product_label_criterion": {
      "type": "object",
      "required": [
        "id",
        "criterion",
        "source_reference",
        "source_text",
        "requirement_type",
        "scoring_logic_ref",
        "input_scope"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "criterion": { "type": "string" },
        "source_reference": { "type": "string" },
        "source_text": { "type": "string" },
        "requirement_type": {
          "type": "string",
          "enum": [
            "numeric_threshold",
            "compliance_attestation",
            "qualitative_assessment",
            "verification_requirement",
            "benchmarking",
            "rollup"
          ]
        },
        "scoring_logic_ref": {
          "type": "string",
          "pattern": "^logic\\.[a-z0-9_]+\\.v\\d+$"
        },
        "input_scope": {
          "type": "array",
          "items": { "type": "string", "enum": ["project", "entity"] },
          "minItems": 1,
          "uniqueItems": true,
          "description": "Input axes this criterion may read. product_label criteria MUST NOT read issuance-level inputs."
        },
        "authority_level": { "type": "integer", "enum": [1, 2, 3] },
        "authority_source": { "type": "string" },
        "snapshot_inclusion": { "type": "boolean" },
        "render_paths": {
          "type": "array",
          "items": { "type": "string", "enum": ["snapshot", "paid_report"] }
        }
      }
    },
    "issuance_criterion": {
      "type": "object",
      "required": [
        "id",
        "criterion",
        "source_reference",
        "source_text",
        "requirement_type",
        "scoring_logic_ref",
        "input_scope"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "criterion": { "type": "string" },
        "source_reference": { "type": "string" },
        "source_text": { "type": "string" },
        "requirement_type": {
          "type": "string",
          "enum": [
            "numeric_threshold",
            "compliance_attestation",
            "qualitative_assessment",
            "verification_requirement",
            "benchmarking",
            "rollup"
          ]
        },
        "scoring_logic_ref": {
          "type": "string",
          "pattern": "^logic\\.[a-z0-9_]+\\.v\\d+$"
        },
        "input_scope": {
          "type": "array",
          "items": { "type": "string", "enum": ["project", "issuance"] },
          "minItems": 1,
          "uniqueItems": true,
          "description": "Input axes this criterion may read. issuance_framework criteria MUST NOT read entity-level inputs."
        },
        "authority_level": { "type": "integer", "enum": [1, 2, 3] },
        "authority_source": { "type": "string" },
        "snapshot_inclusion": { "type": "boolean" },
        "render_paths": {
          "type": "array",
          "items": { "type": "string", "enum": ["snapshot", "paid_report"] }
        }
      }
    },
    "issuance_process_component": {
      "type": "object",
      "required": ["id", "heading", "criteria"],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "use_of_proceeds",
            "project_evaluation_and_selection",
            "management_of_proceeds",
            "reporting"
          ]
        },
        "heading": { "type": "string" },
        "criteria": {
          "type": "array",
          "items": { "$ref": "#/$defs/issuance_criterion" }
        }
      }
    },
    "pai_indicator": {
      "type": "object",
      "required": ["indicator_id", "description", "mandatory"],
      "properties": {
        "indicator_id": { "type": "string" },
        "description": { "type": "string" },
        "mandatory": { "type": "boolean" }
      }
    }
  }
}
